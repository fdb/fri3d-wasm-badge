{
    "name": "wasm3",
    "version": "0.5.0",
    "description": "wasm3 - a fast WebAssembly interpreter (vendored)",
    "keywords": "wasm, webassembly, interpreter",
    "homepage": "https://github.com/wasm3/wasm3",
    "license": "MIT",
    "build": {
        "flags": [
            "-Wno-unused-variable",
            "-Wno-unused-parameter",
            "-Wno-unused-function",
            "-Wno-missing-field-initializers"
        ],
        "srcFilter": [
            "+<*>",
            "-<m3_api_uvwasi.c>",
            "-<m3_api_meta_wasi.c>",
            "-<m3_api_wasi.c>",
            "-<m3_api_tracer.c>"
        ]
    }
}
